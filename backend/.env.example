# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tdarab?schema=public"

# Server
PORT=3000
ENABLE_DOCS=true
ALLOWED_ORIGINS=*

# Trust Proxy — number of reverse proxies between the client and Express.
# Required when the API runs behind any proxy (Cloudflare Tunnel, Nginx, etc.)
# so that express-rate-limit and req.ip read the real client IP from the
# X-Forwarded-For header instead of the proxy's local IP.
#
# Choose the value based on your deployment topology:
#   1  →  Cloudflare Tunnel only                (Client → CF Edge → cloudflared → Express)
#   1  →  Nginx only                            (Client → Nginx → Express)
#   2  →  Cloudflare Tunnel + Nginx             (Client → CF Edge → cloudflared → Nginx → Express)
#   2  →  Cloudflare Proxy + Nginx              (Client → CF Proxy → Nginx → Express)
#
# Never set to `true` in production — it trusts all proxies and enables IP spoofing.
# If unset, the app defaults to 1 (safe for single-proxy deployments).
TRUST_PROXY_HOPS=1

# JWT — generate strong random strings for production
JWT_SECRET="your_strong_jwt_secret_here"
JWT_REFRESH_SECRET="your_strong_refresh_secret_here"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"
